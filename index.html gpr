<!DOCTYPE html>
<html lang="id">

<head>

    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Smart Agriculture IoT Dashboard</title>

    <link rel="stylesheet" href="style.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

<!-- ================= HEADER ================= -->

<div class="header">

    <h1>🌱 SMART AGRICULTURE IoT DASHBOARD</h1>

    <p>
        Monitoring & Kontrol Tanaman Berbasis ESP32 dan ThingSpeak
    </p>

</div>

<!-- ================= SUMMARY ================= -->

<div class="summary">

    <div class="summary-card">

        <h3>🌡️ Temperature</h3>

        <span id="tempValue">0°C</span>

    </div>

    <div class="summary-card">

        <h3>💧 Humidity</h3>

        <span id="humValue">0%</span>

    </div>

    <div class="summary-card">

        <h3>🌱 Soil Moisture</h3>

        <span id="soilValue">0%</span>

    </div>

</div>

<!-- ================= CONTENT ================= -->

<div class="container">

    <!-- ================= CHART ================= -->

    <div class="card">

        <h2>📈 Monitoring Sensor</h2>

        <div class="canvas-container">

            <canvas id="lineDHT"></canvas>

        </div>

    </div>

    <!-- ================= GAUGE ================= -->

    <div class="card">

        <h2>🌱 Soil Moisture</h2>

        <div class="canvas-container">

            <canvas id="gaugeSoil"></canvas>

        </div>

        <div class="status-text">

            Kondisi Tanah :

            <span id="soilTxt">0</span> %

        </div>

    </div>

    <!-- ================= CONTROL ================= -->

    <div class="card">

        <h2>⚙️ Kontrol Aktuator</h2>

        <!-- FAN -->

        <div class="control-group fan-control">

            <h3>🌀 Fan</h3>

            <div class="btn-container">

                <button
                    class="btn-on"
                    onclick="controlDevice('kipas','on')">

                    ON

                </button>

                <button
                    class="btn-off"
                    onclick="controlDevice('kipas','off')">

                    OFF

                </button>

            </div>

            <div class="status-text">

                Status :

                <span id="kipasStatus">
                    OFFLINE
                </span>

            </div>

        </div>

        <!-- PUMP -->

        <div class="control-group pump-control">

            <h3>💧 Pompa</h3>

            <div class="btn-container">

                <button
                    class="btn-on"
                    onclick="controlDevice('pompa','on')">

                    ON

                </button>

                <button
                    class="btn-off"
                    onclick="controlDevice('pompa','off')">

                    OFF

                </button>

            </div>

            <div class="status-text">

                Status :

                <span id="pompaStatus">
                    OFFLINE
                </span>

            </div>

        </div>

        <hr style="margin:25px 0;border-color:#334155;">

        <!-- MODE -->

        <div class="control-group">

            <h3>🖥️ System Mode</h3>

            <div class="status-text">

                Current Mode :

                <span id="modeStatus">

                    AUTO

                </span>

            </div>

            <div class="btn-container">

                <button
                    id="btnAuto"
                    class="btn-auto"
                    onclick="setMode('auto')">

                    AUTO

                </button>

                <button
                    id="btnManual"
                    class="btn-manual"
                    onclick="setMode('manual')">

                    MANUAL

                </button>

            </div>

        </div>

    </div>

</div>

<script src="script.js"></script>

</body>

</html>
