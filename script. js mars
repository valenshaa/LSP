// Konfigurasi ThingSpeak dari file .ino kamu
const CHANNEL_ID = '3399749';
const URL = `https://api.thingspeak.com/channels/${CHANNEL_ID}/feeds.json?results=10`;

// Elemen HTML
const tempEl = document.getElementById('temp');
const humEl = document.getElementById('humidity');
const soilEl = document.getElementById('soil');
const pompaEl = document.getElementById('pompa-status');
const kipasEl = document.getElementById('kipas-status');
const statusBar = document.getElementById('status-bar');

// Inisialisasi Chart.js
const ctx = document.getElementById('sensorChart').getContext('2d');
const sensorChart = new Chart(ctx, {
  type: 'line',
  data: {
    labels: [],
    datasets: [
      { label: 'Suhu (°C)', borderColor: '#e74c3c', data: [], fill: false, tension: 0.2 },
      { label: 'Kelembapan Udara (%)', borderColor: '#3498db', data: [], fill: false, tension: 0.2 },
      { label: 'Kelembapan Tanah (%)', borderColor: '#2ecc71', data: [], fill: false, tension: 0.2 }
    ]
  },
  options: {
    responsive: true,
    scales: {
      y: { beginAtZero: true, max: 100 }
    }
  }
});

// Fungsi Fetch Data dari ThingSpeak
async function fetchData() {
  try {
    const response = await fetch(URL);
    const data = await response.json();
    const feeds = data.feeds;

    if (feeds.length > 0) {
      const lastFeed = feeds[feeds.length - 1];

      // Update nilai di Kartu
      tempEl.innerText = `${parseFloat(lastFeed.field1 || 0).toFixed(1)} °C`;
      humEl.innerText = `${parseFloat(lastFeed.field2 || 0).toFixed(1)} %`;
      soilEl.innerText = `${parseInt(lastFeed.field3 || 0)} %`;

      // Update Status Pompa
      if (parseInt(lastFeed.field4) === 1) {
        pompaEl.innerText = 'ON';
        pompaEl.classList.add('on');
      } else {
        pompaEl.innerText = 'OFF';
        pompaEl.classList.remove('on');
      }

      // Update Status Kipas
      if (parseInt(lastFeed.field5) === 1) {
        kipasEl.innerText = 'ON';
        kipasEl.classList.add('on');
      } else {
        kipasEl.innerText = 'OFF';
        kipasEl.classList.remove('on');
      }

      // Update Grafik
      const labels = feeds.map(f => new Date(f.created_at).toLocaleTimeString());
      const tempVals = feeds.map(f => parseFloat(f.field1));
      const humVals = feeds.map(f => parseFloat(f.field2));
      const soilVals = feeds.map(f => parseFloat(f.field3));

      sensorChart.data.labels = labels;
      sensorChart.data.datasets[0].data = tempVals;
      sensorChart.data.datasets[1].data = humVals;
      sensorChart.data.datasets[2].data = soilVals;
      sensorChart.update();

      statusBar.innerText = '● Live Data Terhubung (ThingSpeak)';
      statusBar.className = 'status-online';
    }
  } catch (error) {
    console.error('Error fetching data:', error);
    statusBar.innerText = '✖ Gagal Mengambil Data ThingSpeak';
    statusBar.className = 'status-offline';
  }
}

// Jalankan saat pertama kali & update otomatis tiap 10 detik
fetchData();
setInterval(fetchData, 10000);
