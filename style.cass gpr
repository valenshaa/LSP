*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:#0f172a;
    color:white;
    min-height:100vh;
    padding:20px;
}

.header{
    text-align:center;
    padding:25px;
    border-radius:20px;
    margin-bottom:25px;

    background:linear-gradient(
        135deg,
        #0ea5e9,
        #10b981
    );

    box-shadow:0 0 25px rgba(0,255,180,.3);
}

.header h1{
    font-size:2rem;
}

.summary{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
    margin-bottom:25px;
}

.summary-card{
    background:#1e293b;
    padding:20px;
    border-radius:20px;
    text-align:center;
    box-shadow:0 0 20px rgba(0,255,180,.1);
}

.summary-card h3{
    margin-bottom:10px;
}

.summary-card span{
    font-size:2rem;
    font-weight:bold;
    color:#22c55e;
}

.container{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(350px,1fr));
    gap:20px;
}

.card{
    background:#1e293b;
    border-radius:20px;
    padding:20px;
    box-shadow:0 0 20px rgba(0,255,180,.1);
}

.card h2{
    margin-bottom:15px;
    color:#38bdf8;
}

.canvas-container{
    height:300px;
}

.control-group{
    background:#0f172a;
    padding:15px;
    border-radius:15px;
    margin-top:15px;
}

.btn-container{
    display:flex;
    gap:10px;
    margin-top:10px;
}

.btn-on,
.btn-off{
    flex:1;
    padding:12px;
    border:none;
    border-radius:12px;
    color:white;
    cursor:pointer;
    font-weight:bold;
}

.btn-on{
    background:#22c55e;
}

.btn-off{
    background:#ef4444;
}

.status-text{
    margin-top:10px;
    font-weight:bold;
}

.btn-auto{
    flex:1;
    padding:12px;
    border:none;
    border-radius:12px;
    background:#3b82f6;
    color:white;
    cursor:pointer;
    font-weight:bold;
}

.btn-manual{
    flex:1;
    padding:12px;
    border:none;
    border-radius:12px;
    background:#f59e0b;
    color:black;
    cursor:pointer;
    font-weight:bold;
}

.mode-active{

    box-shadow:0 0 20px #22c55e;

    transform:scale(1.03);

}

button:disabled{

    opacity:.45;

    cursor:not-allowed;

}
